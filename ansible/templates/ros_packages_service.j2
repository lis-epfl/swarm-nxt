[Unit]
Description=ROS Packages
After=multi-user.target

[Service]
Type=simple
ExecStart=/bin/bash {{ base_path }}/ros_packages_start.sh
KillMode=control-group
KillSignal=SIGTERM
ExecStop=/bin/bash -c "pkill -f ros2cli.daemon.daemonize"
# Graceful shutdown of the cam recorder is impossible under the current
# ros2 launch + systemd cgroup architecture (the recorder gets SIGKILL'd
# mid-finalize when the main PID exits).  Rather than fight that,
# drones_postflight.yml runs scripts/recover_mcap.py on every recording
# to rewrite the truncated file with a proper mcap footer.  That makes
# graceful shutdown unnecessary, so we use SIGKILL and a tiny timeout
# for instant, predictable stops.
KillSignal=SIGKILL
TimeoutStopSec=2
LimitRTPRIO=99

[Install]
WantedBy=multi-user.target

[Unit]
Description=ROS Packages
After=multi-user.target

[Service]
Type=simple
ExecStart=/bin/bash {{ base_path }}/ros_packages_start.sh
KillMode=control-group
KillSignal=SIGTERM
ExecStop=/bin/bash -c "pkill -f ros2cli.daemon.daemonize"
# 60s headroom for graceful shutdown.  oak_compressed_recorder may need to
# write the mcap footer/index for a multi-GB recording before exiting; the
# default 5s was tight and risked SIGKILL truncating the mcap mid-close.
# 30s was enough for the recorder itself but not for some other launch
# children to drain — bumping to 60s eliminates the SIGKILL spam in
# journalctl during postflight stops.
TimeoutStopSec=60
LimitRTPRIO=99

[Install]
WantedBy=multi-user.target

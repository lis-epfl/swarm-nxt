[Unit]
Description=ROS Packages
After=multi-user.target

[Service]
Type=simple
ExecStart=/bin/bash {{ base_path }}/ros_packages_start.sh
KillMode=control-group
ExecStop=/bin/bash -c "pkill -f ros2cli.daemon.daemonize"
# Stop with SIGINT (not SIGKILL) so ROS nodes run their rclcpp on_shutdown
# hooks before exiting -- e.g. the planner's Agent::OnShutdown() creates and
# writes /tmp/planner_logs, which SIGKILL skips entirely.  SIGINT is the signal
# rclcpp reliably turns into rclcpp::shutdown() on Humble (SIGTERM handling is
# version-dependent), so it triggers the on_shutdown callbacks.  systemd still
# escalates to SIGKILL after TimeoutStopSec, so stops stay bounded.
#
# The cam recorder still can't finalize cleanly under ros2 launch + cgroup
# teardown; drones_postflight.yml runs scripts/recover_mcap.py to repair those
# truncated mcaps.  So this grace window only benefits nodes that exit cleanly
# (planner, etc.) -- the recorder is recovered afterward as before.
KillSignal=SIGINT
TimeoutStopSec=10
LimitRTPRIO=99

[Install]
WantedBy=multi-user.target
